# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua-service-key

# gov.br (OAuth2)
GOVBR_CLIENT_ID=seu-client-id
GOVBR_CLIENT_SECRET=seu-client-secret
GOVBR_REDIRECT_URI=https://seu-dominio.com/callback/govbr
GOVBR_ENVIRONMENT=staging

# eSocial
ESOCIAL_CERT_PATH=/certs/certificado.pfx
ESOCIAL_CERT_PASSWORD=senha-do-certificado
ESOCIAL_TIPO_INSCRICAO=1
ESOCIAL_NR_INSCRICAO=00000000000000
# 1 = Producao, 2 = Producao Restrita
ESOCIAL_AMBIENTE=2

# Security
API_SECRET_KEY=sua-chave-secreta-para-api
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.com

# Multi-tenant
REQUIRE_EMPRESA_ID_HEADER=true
ALLOW_GLOBAL_INTEGRATION_FALLBACK=false

# Encryption key for secrets/certificate stored in DB (min 32 chars recommended)
INTEGRATION_ENCRYPTION_KEY=defina-uma-chave-longa-e-aleatoria
